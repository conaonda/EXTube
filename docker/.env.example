# Redis
REDIS_PASSWORD=changeme_use_strong_password

# Docker image settings
DOCKER_IMAGE=extube/app
DOCKER_TAG=latest

# Domain (used for SSL certificate)
DOMAIN=example.com

# Grafana
GRAFANA_PASSWORD=changeme_use_strong_password

# Alertmanager (Slack webhook URL for alerts)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# --- 빌드 및 실행 안내 ---
# 1. 이 파일을 복사하여 .env 파일을 생성합니다:
#    cp .env.example .env
#
# 2. .env 파일의 값을 실제 환경에 맞게 수정합니다.
#    - REDIS_PASSWORD: 강력한 비밀번호로 변경 필수
#    - DOMAIN: 실제 도메인으로 변경
#
# 3. Docker 이미지 빌드:
#    docker compose -f docker-compose.yml -f docker-compose.prod.yml build
#
# 4. 서비스 실행:
#    docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d
#
# 5. GPU 프로파일 포함 실행:
#    docker compose -f docker-compose.yml -f docker-compose.prod.yml --profile gpu up -d
